{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Incharj",
  "version": "0.1.0",
  "identifier": "com.incharj.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Incharj",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
